{
  "manifest_version": 3,
  "name": "Instagram Saved Posts Bulk Unsaver",
  "version": "1.0",
  "description": "Select multiple saved Instagram posts and unsave them in bulk with UI automation.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Instagram Bulk Unsaver"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ]
}
